# Bridge deployment environment
#
# Copy this file to .env before running bridge deployment helpers. Never commit
# real private keys or API keys.

# Required for bridge deployments.
BRIDGE_DEPLOYER_PRIVATE_KEY=your_private_key_here
BRIDGE_NETWORK=sepolia
BRIDGE_ALCHEMY_API_KEY=your_alchemy_api_key_here

# Optional explicit RPC override for non-Alchemy or local endpoints.
# BRIDGE_RPC_URL_OVERRIDE=http://127.0.0.1:8545

# Optional deployment mode. Supported values: upgrade, redeploy-proxy.
# BRIDGE_DEPLOY_MODE=upgrade

# Required for mainnet redeploy-proxy safety checks and artifact uploads.
# The default mainnet deployment history folder is:
# https://drive.google.com/drive/folders/12HuHeR8vCWfkeGdjTAFKhv0FU-AG4aUJ
# GOOGLE_DRIVE_OAUTH_CLIENT_JSON_PATH=./secrets/google-oauth-client.json
# GOOGLE_DRIVE_OAUTH_TOKEN_PATH=./secrets/google-oauth-token.json
# Optional override for the default bridge deployment history folder.
# BRIDGE_DEPLOYMENT_DRIVE_FOLDER_ID=12HuHeR8vCWfkeGdjTAFKhv0FU-AG4aUJ

# Optional Groth16 CRS source. Supported values: trusted, mpc.
# BRIDGE_GROTH_SOURCE=mpc

# Optional bridge ownership and mock asset controls.
# BRIDGE_OWNER=0x0000000000000000000000000000000000000000
# BRIDGE_DEPLOY_MOCK_ASSET=0
# BRIDGE_MOCK_ASSET_NAME=Mock Tokamak Network Token
# BRIDGE_MOCK_ASSET_SYMBOL=TON

# Optional output overrides and refresh skips for advanced workflows.
# BRIDGE_OUTPUT_PATH=bridge/deployments/bridge.11155111.json
# BRIDGE_REFLECTION_MANIFEST_PATH=bridge/deployments/zk-reflection.latest.json
# BRIDGE_SKIP_TOKAMAK_INSTALL=1
# BRIDGE_SKIP_TOKAMAK_VERIFIER_REFRESH=1
# BRIDGE_SKIP_GROTH_REFRESH=1
