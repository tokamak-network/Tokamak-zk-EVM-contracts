# Root environment template for bridge deployment helpers.
# Copy this file to `.env` and replace placeholder values with real secrets.

# Required: private key for the bridge deployer.
# A `0x` prefix is accepted.
BRIDGE_DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Required for public-network bridge deployment.
# Supported values in the bridge helper are `sepolia`, `mainnet`, and `anvil`.
BRIDGE_NETWORK=sepolia

# Required when BRIDGE_NETWORK is `sepolia` or `mainnet`.
# The bridge deploy helper derives the correct Alchemy RPC URL from this key.
BRIDGE_ALCHEMY_API_KEY=YOUR_ALCHEMY_API_KEY

# Optional: explicit RPC override for custom endpoints.
# When set, this takes precedence over the Alchemy-derived URL.
# BRIDGE_RPC_URL_OVERRIDE=https://your-custom-rpc.example

# Optional: transfer ownership of deployed bridge contracts after deployment.
# When unset, ownership stays with the deployer.
# BRIDGE_OWNER=0xYourOwnerAddress

# Optional: bridge deployment parameters.
# The bridge deploy helper resolves BRIDGE_MERKLE_TREE_LEVELS automatically
# from the latest published tokamak-l2js package. Do not set it manually
# unless you are intentionally bypassing the helper.
# BRIDGE_DEPLOY_MOCK_ASSET=false
# BRIDGE_MOCK_ASSET_NAME=Bridge Test Asset
# BRIDGE_MOCK_ASSET_SYMBOL=BTA
# BRIDGE_OUTPUT_PATH=./bridge/deployments/bridge-sepolia.json
